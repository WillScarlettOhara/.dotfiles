[Unit]
Description=SSHFS mount torrent (REDACTED)
After=network-online.target
Wants=network-online.target

[Mount]
What=dockeruser@REDACTED:/home/dockeruser
Where=/mnt/torrent
Type=fuse.sshfs
Options=allow_other,reconnect,ServerAliveInterval=15,ServerAliveCountMax=3,IdentityFile=/home/wills/.ssh/id_rsa

[Install]
WantedBy=multi-user.target
